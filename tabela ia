create table public.ia (
  id_ia bigint generated by default as identity not null,
  ia text not null,
  gasto bigint null,
  empresa - ia bigint null,
  pais bigint null,
  constraint ia_pkey primary key (id_ia),
  constraint ia_id_ia_fkey foreign KEY (id_ia) references empresa (id_empresa)
) TABLESPACE pg_default;
